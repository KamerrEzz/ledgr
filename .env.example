# Application database (non-superuser, RLS enforced)
DATABASE_URL=postgres://app:ledgr_app@localhost:5432/ledgr

# Admin database (superuser, for migrations/seeds only)
DATABASE_ADMIN_URL=postgres://ledgr:ledgr_dev@localhost:5432/ledgr

# JWT
JWT_SECRET=ledgr-dev-secret-change-in-production

# Backend
PORT=3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# Redis
REDIS_URL=redis://localhost:6379
